{
  "name": "harmony",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-02",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "ALLOWED_ORIGIN": "https://harmony.tonari.ai"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
