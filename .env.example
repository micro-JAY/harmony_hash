# Client-side Vite env. Copy to `.env` (gitignored).
# VITE_-prefixed vars are inlined into the browser bundle by Vite — NEVER put a
# secret here. The ElevenLabs API key is a Worker secret (see .dev.vars.example),
# not a client value.

# The voice-companion agent id. Not secret — the browser needs it to connect.
# Printed by scripts/provision-voice-agent.ts.
VITE_HH_VOICE_AGENT_ID=
