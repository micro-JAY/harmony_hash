# Copy this file to `worker/.dev.vars` for local development.
# `.dev.vars*` is gitignored — never commit real keys.
ANTHROPIC_API_KEY=

# Optional. Leave blank to default to "*" during local development.
# In production, set this via `wrangler secret put ALLOWED_ORIGIN` or the dashboard
# (e.g. https://harmony.tonari.ai).
ALLOWED_ORIGIN=
